<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for the host's booking management screen.

    Structure:
    - Title at top
    - Summary row: total pending count
    - RecyclerView with all bookings for this host's hotels
    - Empty state TextView shown when there are no bookings
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_bg">

    <!-- Screen title -->
    <TextView
        android:id="@+id/tvHostBookingsTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/title_host_bookings"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/primary_blue"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Summary card: shows how many bookings are waiting for action.
        Background color is accent_orange to draw the host's attention.
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/summaryCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@color/primary_blue"
        app:layout_constraintTop_toBottomOf="@id/tvHostBookingsTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvPendingCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:gravity="center"
            android:text="@string/pending_count_zero"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Booking list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHostBookings"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/summaryCard"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Empty state: shown when the host has no bookings yet -->
    <TextView
        android:id="@+id/tvEmptyHostBookings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_host_bookings"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/summaryCard"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>