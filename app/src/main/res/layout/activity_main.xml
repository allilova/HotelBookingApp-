<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

        <!-- Top toolbar row: use a horizontal LinearLayout so nothing overlaps -->
        <LinearLayout
            android:id="@+id/toolbarRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Title takes all remaining space -->
            <TextView
                android:id="@+id/tvHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/find_hotel"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Dark mode toggle -->
            <ImageButton
                android:id="@+id/btnDarkMode"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_compass"
                android:contentDescription="@string/cd_toggle_theme"
                app:tint="@color/primary_blue" />

            <!-- Language switcher -->
            <Button
                android:id="@+id/btnLanguage"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="48dp"
                android:layout_height="44dp"
                android:text="EN"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp" />

            <!-- Favourites -->
            <ImageButton
                android:id="@+id/btnGoToFavorites"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/btn_star_big_on"
                android:contentDescription="@string/cd_favorites"
                app:tint="@color/accent_orange" />

            <!-- Bookings -->
            <ImageButton
                android:id="@+id/btnGoToBookings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_agenda"
                android:contentDescription="@string/cd_bookings"
                app:tint="@color/primary_blue" />

            <!-- Profile -->
            <ImageButton
                android:id="@+id/btnGoToProfile"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_myplaces"
                android:contentDescription="@string/cd_profile"
                app:tint="@color/primary_blue" />

        </LinearLayout>

        <!-- Bonus points label -->
        <TextView
            android:id="@+id/tvPoints"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bonus_points"
            android:textColor="@color/accent_orange"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/toolbarRow"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Search bar -->
        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:background="@android:color/transparent"
            app:iconifiedByDefault="false"
            app:queryHint="@string/search_hint"
            app:layout_constraintTop_toBottomOf="@id/tvPoints"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Sort chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupSort"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            app:singleSelection="true"
            app:layout_constraintTop_toBottomOf="@id/searchView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPriceAsc"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sort_price_asc" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPriceDesc"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sort_price_desc" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRating"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sort_rating" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Empty state label -->
        <TextView
            android:id="@+id/tvEmptySearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_hotels_found"
            android:textSize="16sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/chipGroupSort"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Hotel list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHotels"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/chipGroupSort"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- FAB: only shown to HOST users -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddHotel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="@string/add_hotel_title"
        android:visibility="gone"
        app:backgroundTint="@color/accent_orange"
        app:tint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>