<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout-land/activity_hotel_detail.xml
     Side-by-side landscape layout: image on the left, details scrollable on the right -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/white">

    <!-- Left: fixed image + favourite button -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/detailImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:transitionName="hotelImageTransition" />

        <ImageButton
            android:id="@+id/btnFavorite"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="end|top"
            android:layout_margin="12dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="@string/cd_favorite_toggle"
            app:tint="@color/accent_orange" />
    </FrameLayout>

    <!-- Right: scrollable details -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/detailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/detailPrice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_blue" />

                <TextView
                    android:id="@+id/detailAvailability"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:text="—" />
            </LinearLayout>

            <RatingBar
                android:id="@+id/detailRating"
                style="?android:attr/ratingBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:numStars="5"
                android:stepSize="0.5"
                android:isIndicator="true"
                android:progressTint="@color/accent_orange" />

            <TextView
                android:id="@+id/detailDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/black" />

            <org.osmdroid.views.MapView
                android:id="@+id/map"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="10dp" />

            <Button
                android:id="@+id/btnPickDates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/pick_dates"
                android:backgroundTint="@color/primary_blue" />

            <TextView
                android:id="@+id/tvSelectedDates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textSize="13sp"
                android:textColor="@color/primary_blue"
                android:gravity="center" />

            <Button
                android:id="@+id/btnViewAR"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/view_ar"
                android:backgroundTint="#673AB7"
                app:icon="@android:drawable/ic_menu_camera" />

            <Button
                android:id="@+id/btnBookNow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/book_now"
                android:backgroundTint="@color/accent_orange"
                android:padding="14dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>